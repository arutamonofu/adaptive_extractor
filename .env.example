# .env.example
# Copy this file to .env and fill in your actual values

# =============================================================================
# Environment Selection
# =============================================================================
# Environment (dev, test, prod) - controls environment-specific config loading
# This determines which config file to load: config/{env}.yaml
AEE_ENV=dev

# =============================================================================
# Ollama URLs (REQUIRED if use_ollama: true in YAML config)
# =============================================================================
# These must be set in .env file. No fallback or default value is provided.
# Set the actual Ollama server URLs for student and teacher models.
OLLAMA_STUDENT_BASE_URL=http://localhost:11434
OLLAMA_TEACHER_BASE_URL=http://localhost:11434

# =============================================================================
# LLM API Keys (REQUIRED if use_ollama: false in YAML config)
# =============================================================================
# Uncomment and set the appropriate API key(s) for non-Ollama providers.
# At least one must be set if using non-Ollama models.
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# Gemini Parser API Key (REQUIRED if parser: gemini)
# =============================================================================
# Set this if you are using the Gemini PDF parser (config/systems/*.yaml)
# GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Infrastructure
# =============================================================================
# MLflow Tracking
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# DSPy Cache (absolute path recommended)
DSPY_CACHE_DIR=${HOME}/.dspy_cache

# =============================================================================
# Notes
# =============================================================================
# - YAML configuration file is REQUIRED. Use --config CLI argument or AEE_ENV.
# - Environment variables with double underscores (e.g., OPTIMIZATION__NUM_TRIALS)
#   are NOT supported in the current implementation.
# - Ollama URLs and API keys must be set in this file (.env), NOT in YAML.